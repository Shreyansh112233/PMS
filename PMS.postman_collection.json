					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/projects/{{projectId}}/tasks",
							"host": ["{{baseUrl}}"],
							"path": ["projects", "{{projectId}}", "tasks"]
						}
					},
					"auth": {
						"type": "bearer",
						"bearer": [
							{
								"key": "token",
								"value": "{{accessToken}}"
							}
						]
					}
				},
				{
					"name": "Update Task",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Updated task title\",\n  \"description\": \"Updated description\",\n  \"priority\": \"critical\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/tasks/{{taskId}}",
							"host": ["{{baseUrl}}"],
							"path": ["tasks", "{{taskId}}"]
						}
					},
					"auth": {
						"type": "bearer",
						"bearer": [
							{
								"key": "token",
								"value": "{{accessToken}}"
							}
						]
					}
				},
				{
					"name": "Update Task Status",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"in_progress\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/tasks/{{taskId}}/status",
							"host": ["{{baseUrl}}"],
							"path": ["tasks", "{{taskId}}", "status"]
