					},
					"auth": {
						"type": "bearer",
						"bearer": [
							{
								"key": "token",
								"value": "{{accessToken}}"
							}
						]
					}
				},
				{
					"name": "Assign Task",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"assignedTo\": \"{{userId}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/tasks/{{taskId}}/assign",
							"host": ["{{baseUrl}}"],
							"path": ["tasks", "{{taskId}}", "assign"]
